  },
  "license": "MIT",
  "author": "FujishigeTemma",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/FujishigeTemma/vite-plugin-stickynote.git",
    "directory": "packages/vue"
  },
  "files": [
    "dist",
    "src"
  ],
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.mts",
