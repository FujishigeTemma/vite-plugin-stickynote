{
  "name": "vite-plugin-stickynote",
  "version": "0.0.0",
  "description": "In-app comment overlay for Vue dev environments — pin coordinates, threads, and replies, persisted via a Cloudflare Worker + D1.",
  "license": "MIT",
  "files": [
    "dist"
  ],
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.mts",
      "import": "./dist/index.mjs"
    },
    "./runtime/overlay": {
      "types": "./dist/runtime/overlay.d.mts",
      "import": "./dist/runtime/overlay.mjs"
    },
    "./package.json": "./package.json"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "vp pack",
    "dev": "vp pack --watch",
    "check": "vp check",
    "prepublishOnly": "vp run build"
  },
  "dependencies": {
    "vite-plugin-vue-inspector": "^6.0.0",
    "vue": "^3.5.13"
  },
  "devDependencies": {
    "@tsdown/css": "^0.22.0",
    "@types/node": "catalog:",
    "@vitejs/plugin-vue": "^5.2.1",
    "typescript": "catalog:",
    "vite": "catalog:",
    "vite-plus": "catalog:"
  },
  "peerDependencies": {
    "vite": "^5.0.0 || ^6.0.0 || ^7.0.0"
  }
}
