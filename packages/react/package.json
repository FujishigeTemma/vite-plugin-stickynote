    "@babel/types": "^7.27.0",
    "@tanstack/react-query": "^5.95.2",
    "hono": "^4.12.18",
    "magic-string": "^0.30.21",
    "zustand": "^5.0.2"
  },
  "devDependencies": {
    "@tanstack/react-router": "^1.95.0",
    "@types/babel__traverse": "^7.20.6",
    "@types/node": "catalog:",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vite-plugin-stickynote/worker": "workspace:*",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "typescript": "catalog:",
    "vite": "catalog:",
    "vite-plus": "catalog:"
  },
