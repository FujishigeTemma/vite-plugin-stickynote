{
  "name": "@vite-plugin-stickynote/react",
  "version": "0.1.0",
  "description": "In-app comment overlay for React dev environments — pin coordinates, threads, and replies, persisted via a Cloudflare Worker + D1. Targets React 19 + TanStack Router.",
  "keywords": [
    "annotation",
    "comments",
    "feedback",
    "overlay",
    "qa",
    "react",
    "react19",
    "review",
    "tanstack-router",
    "vite",
    "vite-plugin"
  ],
  "homepage": "https://github.com/FujishigeTemma/vite-plugin-stickynote#readme",
  "bugs": {
    "url": "https://github.com/FujishigeTemma/vite-plugin-stickynote/issues"
  },
  "license": "MIT",
  "author": "FujishigeTemma",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/FujishigeTemma/vite-plugin-stickynote.git",
    "directory": "packages/react"
  },
  "files": [
    "dist",
    "src"
  ],
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.mts",
      "import": "./dist/index.mjs"
    },
    "./client": {
      "types": "./dist/client.d.mts",
      "import": "./dist/client.mjs"
    },
    "./package.json": "./package.json"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "vp pack",
    "dev": "vp pack --watch",
    "check": "vp check",
    "prepublishOnly": "vp run build"
  },
  "dependencies": {
    "@babel/parser": "^7.27.0",
